# Herdr config. Place at ~/.config/herdr/config.toml (managed by chezmoi).
onboarding = false

[theme]
# Follow the host terminal's light/dark appearance and switch Herdr's UI
# theme to match. Ghostty reports its appearance and follows macOS, so Herdr
# tracks the system theme transitively.
auto_switch = true
dark_name = "catppuccin"
light_name = "catppuccin-latte"

[keys]
# Cycle focus across agent panes directly (no prefix needed).
# ctrl+letter chords are the reliable direct-binding class; modified Tab
# often doesn't survive terminal key encoding.
next_agent = "ctrl+alt+n"
previous_agent = "ctrl+alt+p"

# Quick scratch terminal: right-side split next to the focused pane;
# closes when the shell exits. (type = "pane" would open an overlay instead.)
[[keys.command]]
key = "prefix+t"
type = "shell"
command = "herdr pane split --current --direction right --ratio 0.35 --focus"

[terminal]
# New panes/tabs/workspaces default here when no explicit --cwd is given.
new_cwd = {{ .herdrDefaultCwd | quote }}

[ui]
# Prompt for a tab name on creation instead of auto-generating one.
prompt_new_tab_name = true

# Show detected/reported agent labels in split pane borders when no manual
# pane name is set.
show_agent_labels_on_pane_borders = true

# Native macOS desktop notifications when background agents change state.
agent_panel_sort = "priority"
[ui.toast]
delivery = "system"

# Play sounds when agents change state in background workspaces (droid muted by default).
[ui.sound]
enabled = true

[session]
# Resume AI-agent panes into their native conversation sessions after a
# Herdr server restart (requires integrations that report session refs).
resume_agents_on_restore = true

[experimental]
# Inline image rendering via Ghostty's Kitty graphics support.
kitty_graphics = true

#!/bin/sh
set -eu

# mise config checksum: {{ include "private_dot_config/mise/config.toml" | sha256sum }}

# Ensure Homebrew-installed tools are on PATH (e.g. on first apply, when the
# running shell predates the Homebrew install).
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

if ! command -v mise >/dev/null 2>&1; then
  echo "mise not installed; skipping runtime install."
  exit 0
fi

echo "Installing runtimes from mise config..."
mise install

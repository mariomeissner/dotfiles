{{- $gitUserName := index . "gitUserName" -}}
{{- $gitUserEmail := index . "gitUserEmail" -}}
{{- if not $gitUserName -}}
{{- fail "missing gitUserName; run chezmoi init to regenerate local template data" -}}
{{- end -}}
{{- if not $gitUserEmail -}}
{{- fail "missing gitUserEmail; run chezmoi init to regenerate local template data" -}}
{{- end -}}
[user]
	name = {{ $gitUserName | quote }}
	email = {{ $gitUserEmail | quote }}

# Always authenticate to GitHub over SSH, even when a remote is cloned with an
# HTTPS URL. This rewrites https://github.com/... to git@github.com:... on the
# fly, so the SSH key in ~/.ssh/config is used and HTTPS username/token prompts
# go away.
[url "git@github.com:"]
	insteadOf = https://github.com/

[init]
	defaultBranch = main

[core]
	editor = vim
	autocrlf = input
	pager = delta

[color]
	ui = auto

[column]
	ui = auto

[branch]
	autoSetupMerge = simple
	sort = -committerdate

[checkout]
	defaultRemote = origin

[tag]
	sort = version:refname

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[delta]
	navigate = true
	side-by-side = false
	line-numbers = true

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictStyle = zdiff3

[fetch]
	prune = true
	pruneTags = true

[pull]
	ff = only

[push]
	default = current
	autoSetupRemote = true
	followTags = true

[commit]
	verbose = true

[rerere]
	enabled = true

[rebase]
	autoStash = true
	updateRefs = true
